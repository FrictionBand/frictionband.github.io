<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link rel="apple-touch-icon" sizes="180x180" href="{{ site.baseUrl }}/assets/favicon/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ site.baseUrl }}/assets/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ site.baseUrl }}/assets/favicon/favicon-16x16.png">
  <link rel="manifest" href="{{ site.baseUrl }}/assets/favicon/site.webmanifest">

  <!-- hreflang for language alternates -->
  {% if lang == 'en' %}
  <link rel="alternate" hreflang="en" href="{{ page.url }}">
  <link rel="alternate" hreflang="fi" href="/fi{{ page.url }}">
  {% elif lang == 'fi' %}
  <link rel="alternate" hreflang="en" href="{{ page.url | replace('/fi', '') }}">
  <link rel="alternate" hreflang="fi" href="{{ page.url }}">
  {% endif %}

  <!-- stylesheet -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
  <link rel="stylesheet" href="{{ site.baseUrl }}/{{ 'assets/css/tailwind.css' | url }}">
  <link rel="stylesheet" href="{{ site.baseUrl }}/assets/css/tobii.min.css">

  <!-- Meta -->
  <title>{{site.title}}{% if title %} - {{title}} {% endif %} </title>
  <meta name="description" content="
      {% if description %}
        {{description}}
      {% else %}
        {{site.description}}
      {% endif %}
    " />

</head>

<body class="bg-neutral-900">

  {% include "partials/_navigation.njk" %}

  <div class="pt-16">
    {{ content | safe }}
  </div>

  {% include "partials/_footer.njk" %}

  <script src="{{ site.baseUrl }}/assets/js/menu.js"></script>
  <script src="{{ site.baseUrl }}/assets/js/email.js"></script>

  <script>
    // Set a global varialbe that enables / disables Lightbox
    // Make it a property of the window object to ensure global accessibility
    window.enableLightbox = {{ enableLightbox | default(false) | safe }};
  </script>
  <script src="{{ site.baseUrl }}/assets/js/tobii.min.js"></script>
  <script src="{{ site.baseUrl }}/assets/js/lightbox.js"></script>

  <script src="{{ site.baseUrl }}/assets/js/video.js"></script>

  <!-- Sticky audio player (hidden until play is triggered) -->
  <div id="audio-player-bar"
      class="fixed bottom-0 left-0 right-0 z-50 bg-neutral-900"
      style="transform: translateY(100%); transition: transform 0.3s ease;">
    <!-- Gradient shadow + border above the bar -->
    <div class="absolute inset-x-0 -top-8 h-8 pointer-events-none border-b border-neutral-700"
        style="background: linear-gradient(to bottom, transparent, rgba(23,23,23,0.6));"></div>
    <div class="max-w-3xl mx-auto px-5 py-3 flex items-center gap-4">
      <!-- Play/pause -->
      <button id="player-playpause" aria-label="Play/pause"
          class="w-9 h-9 rounded-full border border-neutral-500 text-neutral-300 hover:text-white hover:border-white flex items-center justify-center flex-shrink-0 transition-colors">
        <i id="player-icon" class="fa-solid fa-play text-xs ml-0.5"></i>
      </button>
      <!-- Track info -->
      <div class="flex-1 min-w-0">
        <div class="text-xs text-neutral-100 truncate"><span class="font-semibold">Friction</span> <span class="text-neutral-400">— Live medley</span></div>
        <!-- Progress bar -->
        <div class="mt-1.5 h-1 bg-neutral-700 rounded-full w-full">
          <div id="player-progress" class="h-full bg-primary-500 rounded-full" style="width: 0%;"></div>
        </div>
      </div>
      <!-- Close -->
      <button id="player-close" aria-label="Close player"
          class="text-neutral-500 hover:text-neutral-300 flex-shrink-0 transition-colors">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <audio id="friction-audio" src="/assets/audio/medley.mp3" preload="metadata"></audio>
  </div>

  <script src="{{ site.baseUrl }}/assets/js/player.js"></script>
</body>

</html>
