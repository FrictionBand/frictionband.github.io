{% if heroImage or heroVideo %}
<div class="relative overflow-hidden bg-neutral-900 -mb-32" style="height: 70vh; min-height: 36rem; max-height: 42rem;">
    <!-- Background gradient overlay -->
    <div class="absolute inset-0 z-10"
        style="background: linear-gradient(to bottom, transparent 0%, rgb(23, 23, 23) 100%);">
    </div>

    <!-- Background image (video fallback, or main image if no video) -->
    {% if heroImage %}
    <img src="{{ heroImage }}" alt=""
        class="absolute top-0 left-0 w-full h-full object-cover z-5">
    {% endif %}

    <!-- Video (optional) -->
    {% if heroVideo %}
    <video preload="none" autoplay loop muted playsinline
        class="absolute top-1/2 left-1/2 w-full h-full -translate-x-1/2 -translate-y-1/2 z-0"
        style="object-fit: cover;">
        <source src="{{ heroVideo }}" type="video/mp4">
    </video>
    {% endif %}

    <!-- Logo + slogan (optional) -->
    {% if heroShowLogo %}
    <div class="absolute top-[40%] left-1/2 -translate-x-1/2 -translate-y-1/2 text-center z-20 flex flex-col items-center gap-4">
        <img src="/assets/images/friction-logo-new.png" alt="Friction"
            class="md:w-96 mx-auto drop-shadow-lg">
        <div class="text-sm md:text-base font-semibold tracking-widest uppercase text-neutral-300 drop-shadow max-w-xs md:max-w-sm leading-relaxed">
            {{ slogan if slogan else site.slogan }}</div>
    </div>
    {% endif %}
</div>
{% endif %}
