{% set t = i18n[lang | default('en')].book %}
{# allow overriding the button text via `label` parameter passed from shortcode renderer
  if omitted, fall back to a fixed placeholder 'services' (no i18n) #}
{% set labelText = label or 'services' %}
<section class="text-center my-4 md:my-16 mx-2">
  {% if lang == 'fi' %}
    <a href="/fi/book/" class="inline-block bg-primary-600 text-white hover:text-white px-6 py-2 rounded-full hover:bg-primary-500 transition-colors">{{ labelText }}</a>
  {% else %}
    <a href="/book/" class="inline-block bg-primary-600 text-white hover:text-white px-6 py-2 rounded-full hover:bg-primary-500 transition-colors">{{ labelText }}</a>
  {% endif %}
</section>
