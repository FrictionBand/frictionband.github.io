{% if items and items | length > 0 %}
<section class="overflow-visible">

  <div class="prose">
    <h2 class="mt-16 mb-14" id="gigs">{{ heading }}</h2>
  </div>

  {% for gig in items %}
  <a href="{{ gig.url }}" class="relative block border border-neutral-700 hover:border-neutral-500 mb-12 transition-colors no-underline group {{ 'sm:mt-8 sm:ml-5 sm:pl-44' if gig.image else '' }}">
    {% if gig.image %}
    {# Desktop: absolute offset thumbnail #}
    <div class="hidden sm:block absolute -top-5 bottom-5 -left-5 overflow-hidden border border-neutral-600" style="width:160px;">
      <img src="{{ gig.image }}" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;margin:0;">
    </div>
    {# Mobile: full-width image on top #}
    <div class="sm:hidden w-full overflow-hidden" style="height:180px;">
      <img src="{{ gig.image }}" alt="" style="width:100%;height:100%;object-fit:cover;margin:0;">
    </div>
    {% endif %}
    <div class="flex items-start justify-between gap-4 p-5">
      <div class="flex-1 min-w-0">
        <div class="text-xs font-semibold tracking-widest uppercase text-neutral-400 mb-1">{{ gig.dateStr }}{% if gig.time %} · {{ gig.time }}{% endif %}</div>
        <div class="text-base font-bold text-neutral-100 leading-snug">{{ gig.title }}</div>
        {% if gig.location %}
        <div class="text-sm text-neutral-400 mt-1 flex items-center gap-1"> {{ gig.location }}</div>
        {% endif %}
      </div>
      <div class="text-neutral-500 group-hover:text-neutral-300 transition-colors flex-shrink-0 text-lg mt-1">→</div>
    </div>
  </a>
  {% endfor %}

</section>
{% endif %}
