---
layout: base
---

{% set heroImage = image %}
{% include "partials/_hero.njk" %}

<main class="relative z-10 max-w-3xl mx-auto w-full p-5 {{ 'mt-0' if image else 'mt-6' }}">

  <h1 class="text-3xl md:text-4xl font-bold text-neutral-100 mb-8 leading-tight not-prose">{{ title }}</h1>

  <div class="border border-neutral-700 rounded-lg p-5 mb-8 not-prose">
    <ul class="space-y-3 list-none pl-0 m-0">
      <li class="text-neutral-300 flex items-center gap-3">
        <i class="fa-regular fa-calendar w-5 text-center"></i><span>{{ date | postDate }}</span>
      </li>
      {% if time %}
      <li class="text-neutral-300 flex items-center gap-3">
        <i class="fa-regular fa-clock w-5 text-center"></i><span>{{ time }}</span>
      </li>
      {% endif %}
      {% if gmaps %}
      <li class="text-neutral-300 flex items-center gap-3">
        <i class="fas fa-map-marker-alt w-5 text-center"></i>
        <a href="{{ gmaps }}" class="text-primary-400 hover:text-primary-300">{{ location or gmaps }} →</a>
      </li>
      {% endif %}
      {% if fblink %}
      <li class="text-neutral-300 flex items-center gap-3">
        <i class="fab fa-facebook-f w-5 text-center"></i>
        <a href="{{ fblink }}" class="text-primary-400 hover:text-primary-300">Facebook Event →</a>
      </li>
      {% endif %}
      {% if weblink %}
      <li class="text-neutral-300 flex items-center gap-3">
        <i class="fa-solid fa-link w-5 text-center"></i>
        <a href="{{ weblink }}" class="text-primary-400 hover:text-primary-300">More info →</a>
      </li>
      {% endif %}
    </ul>
  </div>

  <div class="prose">{{ content | safe }}</div>

</main>
