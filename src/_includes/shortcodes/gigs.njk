{% if items and items | length > 0 %}
<section class="overflow-visible">

  <div class="prose">
    <h2 class="mt-16 mb-14" id="gigs">{{ heading }}</h2>
  </div>

  {% for gig in items %}
  <a href="{{ gig.url }}" class="relative block border border-neutral-700 hover:border-neutral-500 p-5 mb-12 transition-colors no-underline group {{ 'mt-8 ml-5 pl-44' if gig.image else '' }}">
    {% if gig.image %}
    <div class="absolute -top-5 bottom-5 -left-5 overflow-hidden border border-neutral-600" style="width:160px;">
      <img src="{{ gig.image }}" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;margin:0;">
    </div>
    {% endif %}
    <div class="flex items-center justify-between gap-4">
      <div class="flex-1 min-w-0">
        <div class="text-xs font-semibold tracking-widest uppercase text-neutral-400 mb-1">{{ gig.dateStr }}{% if gig.time %} · {{ gig.time }}{% endif %}</div>
        <div class="text-base font-bold text-neutral-100 leading-snug">{{ gig.title }}</div>
        {% if gig.location %}
        <div class="text-sm text-neutral-400 mt-1 flex items-center gap-1"> {{ gig.location }}</div>
        {% endif %}
      </div>
      <div class="text-neutral-500 group-hover:text-neutral-300 transition-colors flex-shrink-0 text-lg">→</div>
    </div>
  </a>
  {% endfor %}

</section>
{% endif %}
