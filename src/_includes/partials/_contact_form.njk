{% set formLang = lang if lang else 'en' %}
{% set ft = i18n[formLang].contactForm %}

<form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="not-prose space-y-5 mt-8">
  <input type="hidden" name="access_key" value="0140b0c4-ce30-477a-b23e-7e6bf71537f0">
  <input type="hidden" name="subject" id="cf-subject" value="Friction Website Submission">
  <input type="hidden" name="redirect" value="{{ site.url }}{% if lang == 'fi' %}/fi/kiitos/{% else %}/thank-you/{% endif %}">
  {# Honeypot — bots fill this, humans don't #}
  <input type="checkbox" name="botcheck" class="hidden" style="display:none;" tabindex="-1" autocomplete="off">

  <div>
    <label for="cf-name" class="block text-sm font-semibold text-neutral-300 mb-1">{{ ft.name }}</label>
    <input id="cf-name" type="text" name="name" required autocomplete="name"
      class="w-full bg-neutral-800 border border-neutral-600 text-neutral-100 placeholder-neutral-500 rounded px-4 py-2 focus:outline-none focus:border-primary-500 transition-colors">
  </div>

  <div>
    <label for="cf-email" class="block text-sm font-semibold text-neutral-300 mb-1">{{ ft.email }}</label>
    <input id="cf-email" type="email" name="email" required autocomplete="email"
      class="w-full bg-neutral-800 border border-neutral-600 text-neutral-100 placeholder-neutral-500 rounded px-4 py-2 focus:outline-none focus:border-primary-500 transition-colors">
  </div>

  <div>
    <label for="cf-message" class="block text-sm font-semibold text-neutral-300 mb-1">{{ ft.message }}</label>
    <textarea id="cf-message" name="message" rows="5" required
      class="w-full bg-neutral-800 border border-neutral-600 text-neutral-100 placeholder-neutral-500 rounded px-4 py-2 focus:outline-none focus:border-primary-500 transition-colors resize-y"></textarea>
  </div>

  <button type="submit"
    class="bg-primary-600 hover:bg-primary-500 text-white font-semibold px-6 py-2 rounded-full transition-colors">
    {{ ft.send }}
  </button>
</form>

<p id="cf-success" class="hidden text-neutral-100 font-semibold mt-4">{{ ft.success }}</p>

<p class="text-sm text-neutral-500 mt-6">{{ ft.orEmail }} <a href="mailto:contact@friction-helsinki.com" class="text-primary-400 hover:text-primary-300">contact@friction-helsinki.com</a></p>

<script>
(function () {
  var name = document.getElementById('cf-name');
  var subject = document.getElementById('cf-subject');
  name.addEventListener('input', function () {
    subject.value = name.value.trim()
      ? name.value.trim() + ' via Friction Website Form'
      : 'Friction Website Submission';
  });
})();
</script>

<noscript>
  <p class="text-neutral-300 mt-4">{{ ft.noscript }} <a href="mailto:contact@friction-helsinki.com" class="text-primary-400 hover:text-primary-300">contact@friction-helsinki.com</a></p>
</noscript>
