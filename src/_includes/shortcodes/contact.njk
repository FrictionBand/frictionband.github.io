{% set t = i18n[lang | default('en')].contact %}
<section class="text-center my-16">
    <button class="email hidden bg-sky-500 text-white px-6 py-2 rounded-full hover:bg-sky-400 transition-colors">{{ t.button }}</button>
    <noscript>
        <p class="text-neutral-300">{{ t.noscript }}</p>
    </noscript>
</section>
