{% if items and items | length > 0 %}
<section>

  <div class="prose">
    <h2 class="mt-16 mb-10" id="gigs">{{ heading }}</h2>
  </div>

  {% for gig in items %}

  <h4 class="mb-1 text-neutral-100 font-semibold">{{ gig.dateStr }} - {{ gig.title }}</h4>

  {# Always show short description when available (brief teaser) #}
  {% if gig.short %}
    <div class="text-neutral-300 mb-1">{{ gig.short | safe }}</div>
  {% endif %}

  {# Show the full description only when `showDescription` is true #}
  {% if showDescription and gig.content %}
    <div class="text-neutral-300 mb-1">{{ gig.content | safe }}</div>
  {% endif %}

  <ul class="mb-4 list-none pl-0 space-y-1">
    {% if gig.time %}
    <li class="text-neutral-300 flex items-center gap-2"><i class="fa-regular fa-clock w-5 text-center"></i><span>{{ gig.time }}</span></li>
    {% endif %}

    {% if gig.gmaps %}
    <li class="text-neutral-300 flex items-center gap-2"><i class="fas fa-map-marker-alt w-5 text-center"></i><a href="{{ gig.gmaps }}" class="text-primary-400 hover:text-primary-300">{{ gig.location or gig.gmaps }}</a></li>
    {% endif %}

    {% if gig.fblink %}
    <li class="text-neutral-300 flex items-center gap-2"><i class="fab fa-facebook-f w-5 text-center"></i><a href="{{ gig.fblink }}" class="text-primary-400 hover:text-primary-300">{{ gig.fblink }}</a></li>
    {% endif %}

    {% if gig.weblink %}
    <li class="text-neutral-300 flex items-center gap-2"><i class="fa-solid fa-link w-5 text-center"></i><a href="{{ gig.weblink }}" class="text-primary-400 hover:text-primary-300">{{ gig.weblink }}</a></li>
    {% endif %}
  </ul>

  {% endfor %}

</section>
{% endif %}
