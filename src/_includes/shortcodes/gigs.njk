{% if items and items | length > 0 %}
<section class="overflow-visible">

  <div class="prose">
    <h2 class="mt-16 mb-14" id="gigs">{{ heading }}</h2>
  </div>

  {% for gig in items %}

  {% if gig.featured %}
  {# ── Featured gig: large full-bleed card ── #}
  <a {% if linkCards %}href="{{ jamUrl if gig.type == 'jam' else gig.url }}"{% endif %} class="not-prose flex flex-col border-2 border-neutral-400 {% if linkCards %}hover:border-white transition-colors no-underline group cursor-pointer{% endif %} mb-12">
    {% if gig.heroImage %}
    <div class="w-full overflow-hidden" style="height:320px;">
      <img src="{{ gig.heroImage }}" alt="" style="width:100%;height:100%;object-fit:cover;margin:0;">
    </div>
    {% endif %}
    <div class="flex flex-1 items-start justify-between gap-4 p-5">
      <div class="flex-1 min-w-0">
        <div class="text-xs font-semibold tracking-widest uppercase text-neutral-400 mb-1">{{ gig.dateStr }}{% if gig.time %} · {{ gig.time }}{% endif %}</div>
        <div class="text-2xl font-bold text-white leading-snug">{{ gig.title }}</div>
        {% if gig.location %}
        <div class="text-sm text-neutral-400 mt-2 flex items-center gap-1">{{ gig.location }}</div>
        {% endif %}
      </div>
      {% if linkCards %}<div class="text-neutral-500 group-hover:text-neutral-300 transition-colors flex-shrink-0 text-2xl mt-1">→</div>{% endif %}
    </div>
  </a>

  {% else %}
  {# ── Regular gig card ── #}
  <a {% if linkCards %}href="{{ jamUrl if gig.type == 'jam' else gig.url }}"{% endif %} class="not-prose relative flex flex-col border border-neutral-700 {% if linkCards %}hover:border-neutral-500 transition-colors no-underline group cursor-pointer{% endif %} mb-12 {{ 'sm:mt-8 sm:ml-5 sm:pl-44 sm:min-h-[160px]' if gig.heroImage else '' }}">
    {% if gig.heroImage %}
    {# Desktop: absolute offset thumbnail #}
    <div class="hidden sm:block absolute -top-5 bottom-5 -left-5 overflow-hidden border border-neutral-600" style="width:160px;">
      <img src="{{ gig.heroImage }}" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;margin:0;">
    </div>
    {# Mobile: full-width image on top #}
    <div class="sm:hidden w-full overflow-hidden" style="height:180px;">
      <img src="{{ gig.heroImage }}" alt="" style="width:100%;height:100%;object-fit:cover;margin:0;">
    </div>
    {% endif %}
    <div class="flex flex-1 items-center justify-between gap-4 p-5">
      <div class="flex-1 min-w-0">
        <div class="text-xs font-semibold tracking-widest uppercase text-neutral-400 mb-1">{{ gig.dateStr }}{% if gig.time %} · {{ gig.time }}{% endif %}</div>
        <div class="text-base font-bold text-neutral-100 leading-snug">{{ gig.title }}</div>
        {% if gig.location %}
        <div class="text-sm text-neutral-400 mt-1 flex items-center gap-1"> {{ gig.location }}</div>
        {% endif %}
      </div>
      {% if linkCards %}<div class="text-neutral-500 group-hover:text-neutral-300 transition-colors flex-shrink-0 text-lg mt-1">→</div>{% endif %}
    </div>
  </a>
  {% endif %}

  {% endfor %}

  {% if hasMore %}
  <div class="not-prose -mt-6 mb-14">
    <a href="{{ moreUrl }}" class="text-primary-400 hover:text-primary-300 transition-colors">{{ seeAllText }}</a>
  </div>
  {% endif %}

</section>
{% endif %}
