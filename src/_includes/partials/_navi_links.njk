{% set currentLang = lang if lang else 'en' %}
{% set t = i18n[currentLang] %}

{% if lang %}
  {% if currentLang == 'fi' %}
    {% set otherUrl = page.url | replace('/fi', '') %}
  {% else %}
    {% set otherUrl = '/fi' + page.url %}
  {% endif %}
{% else %}
  {% set otherUrl = '/fi/' %}
{% endif %}

<!-- Home link — mobile overlay only -->
{% if mobileNavi == true %}
{% set homeUrl = '/fi/' if currentLang == 'fi' else '/' %}
<a href="{{ homeUrl }}" class="p-5 uppercase font-extrabold whitespace-nowrap block text-center
    {% if page.url === homeUrl %}text-primary-100{% else %}text-gray-300 hover:text-primary-500{% endif %}">
    {{ t.nav.home }}
</a>
{% endif %}

<!-- If there are gigs, include special "gigs" jump link -->

{% set showGigs = false %}
{% set hasGigs = collections.gigs | filterTodayOrLater | length > 0 %}
{% set gigsUrl = '/fi/#gigs' if currentLang == 'fi' else '/#gigs' %}
<a href="{{ gigsUrl }}" id="gigs-link"
class="p-5 uppercase font-extrabold whitespace-nowrap items-center
{% if not hasGigs or not showGigs %} hidden {% endif %}
{% if mobileNavi == true %} block text-center {% else %} inline-flex {% endif %}
 text-gray-300 hover:text-primary-500">
    {{ t.nav.gigs }}
</a>


<!-- Iterate pages for the current language -->
{% if currentLang == 'fi' %}
  {% set navPages = collections.pagesFi %}
{% else %}
  {% set navPages = collections.pagesEn %}
{% endif %}

{% for item in navPages %}
{% if item.data.title !== "Home" and item.data.title !== "Etusivu" and item.data.hidden != true %}
<a href="{{ site.baseUrl }}{{ item.url }}" class="p-5 uppercase font-extrabold whitespace-nowrap items-center
    {% if mobileNavi == true %} block text-center {% else %} inline-flex {% endif %}
    {% if item.url === page.url %}text-primary-100{% else %}text-gray-300 hover:text-primary-500{% endif %}">
    {{ item.data.title }}
</a>
{% endif %}
{% endfor %}

<!-- Language switcher -->
<a href="{{ otherUrl }}" class="p-5 uppercase font-extrabold whitespace-nowrap items-center
    {% if mobileNavi == true %} block text-center {% else %} inline-flex {% endif %}
    text-gray-300 hover:text-primary-500">
    {{ t.langSwitch.label }}
</a>
